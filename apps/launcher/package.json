{
    "$schema": "https://www.raycast.com/schemas/extension.json",
    "name": "altered-launcher",
    "title": "ALTERED",
    "description": "Organize the thoughts in your ALTERED brain.",
    "icon": "icon.png",
    "author": "inducingchaos",
    "categories": [
        "Productivity"
    ],
    "license": "MIT",
    "commands": [
        {
            "name": "capture",
            "title": "Capture a Thought",
            "subtitle": "ALTERED Capture",
            "description": "Upload a thought.",
            "mode": "view"
        },
        {
            "name": "refine",
            "title": "Refine your Knowledge",
            "subtitle": "ALTERED Refine",
            "description": "View and edit your thoughts.",
            "mode": "view"
        },
        {
            "name": "warp",
            "title": "Warp from Clipboard",
            "subtitle": "ALTERED Warp",
            "description": "Upload a thought from your clipboard.",
            "mode": "no-view"
        },
        {
            "name": "info",
            "title": "Learn about ALTERED",
            "subtitle": "ALTERED Info",
            "description": "Get info on how to start using your ALTERED brain.",
            "mode": "view"
        }
    ],
    "dependencies": {
        "@altered/api": "workspace:*",
        "@altered/db": "workspace:*",
        "@altered/ui": "workspace:*",
        "@altered/validators": "workspace:*",
        "@raycast/api": "^1.96.0",
        "@raycast/utils": "^1.17.0",
        "@tanstack/react-query": "catalog:",
        "@trpc/client": "catalog:",
        "@trpc/tanstack-react-query": "catalog:",
        "react": "catalog:react19",
        "superjson": "2.2.2"
    },
    "devDependencies": {
        "@altered/eslint-config": "workspace:*",
        "@altered/prettier-config": "workspace:*",
        "@altered/tsconfig": "workspace:*",
        "@raycast/eslint-config": "^2.0.4",
        "@types/node": "^22.13.11",
        "@types/react": "19.0.10",
        "eslint": "^9.22.0",
        "prettier": "^3.5.3",
        "typescript": "catalog:"
    },
    "scripts": {
        "build": "ray build",
        "dev": "ray develop",
        "format": "prettier --check . --ignore-path ../../.gitignore",
        "lint:ray": "ray lint",
        "lint:ray:fix": "ray lint --fix",
        "typecheck": "tsc --noEmit --emitDeclarationOnly false",
        "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
        "prepublishOnly": "echo \"\\n\\nIt seems like you are trying to publish the Raycast extension to npm.\\n\\nIf you did intend to publish it to npm, remove the \\`prepublishOnly\\` script and rerun \\`npm publish\\` again.\\nIf you wanted to publish it to the Raycast Store instead, use \\`npm run publish\\` instead.\\n\\n\" && exit 1",
        "publish": "npx @raycast/api@latest publish"
    },
    "prettier": "@altered/prettier-config",
    "preferences": [
        {
            "name": "user-id",
            "title": "User ID",
            "description": "Your unique User ID. Find it at https://altered.app/raycast",
            "type": "password",
            "required": true
        }
    ]
}
